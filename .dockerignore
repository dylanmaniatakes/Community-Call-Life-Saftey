# ── Docker build context exclusions ──────────────────────────────────────────

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Local database (use the Docker volume instead)
*.db
*.db-shm
*.db-wal

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Git
.git/
.gitignore

# Docker files (not needed inside the image)
docker-compose.yml
.dockerignore
nginx/

# Logs
*.log
logs/

# Test / dev files
tests/
test_*.py
*_test.py
